{
  "integrations": [
    {
      "key": "gemini",
      "target_dir": "{{HOME}}/.gemini",
      "templates_dir": "src/ai/integrations/gemini/templates",
      "artifacts": [
        { "src": "GEMINI.md.tmpl", "dst": "GEMINI.md", "type": "template" },
        { "src": "system.md.tmpl", "dst": "system.md", "type": "template" },
        { "src": "config.json.tmpl", "dst": "config.json", "type": "template" }
      ]
    },
    {
      "key": "codex",
      "target_dir": "{{HOME}}/.codex",
      "templates_dir": "src/ai/integrations/codex/templates",
      "artifacts": [
        { "src": "agents.md.tmpl", "dst": "AGENTS.md", "type": "codex_agents" },
        { "src": "config.toml.tmpl", "dst": "config.toml", "type": "codex_config" },
        { "src": "rules.tmpl", "dst": "rules/default.rules", "type": "codex_rules" }
      ]
    }
  ]
}
