#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"

while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  case "$SCRIPT_PATH" in
    /*) ;;
    *) SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}" ;;
  esac
done

REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
# shellcheck disable=SC1091
. "$REPO_DIR/lib/modules/bootstrap.sh"
dev_kit_bootstrap

while IFS= read -r module_file; do
  [ -n "$module_file" ] || continue
  [ "$module_file" = "$REPO_DIR/lib/modules/bootstrap.sh" ] && continue
  # shellcheck disable=SC1090
  . "$module_file"
done <<EOF
$(dev_kit_module_paths)
EOF

for command_file in "$REPO_DIR"/lib/commands/*.sh; do
  # shellcheck disable=SC1090
  . "$command_file"
done

usage() {
  local command_name=""
  local description=""
  cat <<'EOF'
Usage: dev.kit <command>

Commands:
EOF

  while IFS= read -r command_name; do
    description="$(dev_kit_command_description "$(dev_kit_command_file_path "$REPO_DIR" "$command_name")")"
    printf "  %-10s %s\n" "$command_name" "$description"
  done <<EOF
$(dev_kit_public_command_names)
EOF

  cat <<'EOF'
  help       Show this help message

Options:
  --json     Output machine-readable JSON for supported commands
EOF
}

home_usage() {
  echo "Usage: dev.kit [--json]"
  echo
  echo "Shows repo-aware landing output for the current directory."
}

dev_kit_run_home() {
  local format="${1:-text}"
  local state="not installed"
  local repo_dir="$(pwd)"
  local repo_root=""
  local repo_detected="false"
  local repo_kind="workspace"
  local archetype="n/a"
  local profile="n/a"
  local git_state="no"
  local priority_refs=""
  local first_priority_ref=""
  local second_priority_ref=""

  if [ -d "$DEV_KIT_HOME" ]; then
    state="installed"
  fi

  repo_root="$(dev_kit_repo_root "$repo_dir")"
  if [ -n "$repo_root" ]; then
    repo_detected="true"
    repo_kind="repo"
    archetype="$(dev_kit_repo_primary_archetype "$repo_root")"
    profile="$(dev_kit_repo_primary_profile "$repo_root")"
    if dev_kit_sync_has_git_repo "$repo_root"; then
      git_state="yes"
    fi
    priority_refs="$(dev_kit_repo_priority_refs "$repo_root")"
    first_priority_ref="$(printf '%s\n' "$priority_refs" | awk 'NF { print; exit }')"
    second_priority_ref="$(printf '%s\n' "$priority_refs" | awk 'NF { count += 1; if (count == 2) { print; exit } }')"
  fi

  if [ "$format" = "json" ]; then
    printf '{\n'
    printf '  "name": "dev.kit",\n'
    printf '  "home": "%s",\n' "$(dev_kit_json_escape "$DEV_KIT_HOME")"
    printf '  "state": "%s",\n' "$(dev_kit_json_escape "$state")"
    printf '  "workspace": {\n'
    printf '    "path": "%s",\n' "$(dev_kit_json_escape "$repo_dir")"
    printf '    "repo_detected": %s,\n' "$repo_detected"
    printf '    "kind": "%s"' "$(dev_kit_json_escape "$repo_kind")"
    if [ "$repo_detected" = "true" ]; then
      printf ',\n    "repo": { "name": "%s", "root": "%s", "archetype": "%s", "profile": "%s", "git": %s, "markers": %s, "first_priority_ref": "%s" }\n' \
        "$(dev_kit_json_escape "$(dev_kit_repo_name "$repo_root")")" \
        "$(dev_kit_json_escape "$repo_root")" \
        "$(dev_kit_json_escape "$archetype")" \
        "$(dev_kit_json_escape "$profile")" \
        "$([ "$git_state" = "yes" ] && printf 'true' || printf 'false')" \
        "$(dev_kit_repo_markers_json "$repo_root")" \
        "$(dev_kit_json_escape "$first_priority_ref")"
    else
      printf '\n'
    fi
    printf '  },\n'
    printf '  "localhost_tools": %s,\n' "$(dev_kit_env_tools_json)"
    if [ "$repo_detected" = "true" ] && [ "$git_state" = "yes" ]; then
      printf '  "start_here": %s,\n' "$(dev_kit_sync_start_here_json "$repo_root")"
      printf '  "agent_contract": %s,\n' "$(dev_kit_repo_agent_contract_json "$repo_root")"
    else
      printf '  "start_here": [],\n'
      printf '  "agent_contract": [],\n'
    fi
    printf '  "helpers": [\n'
    printf '    { "id": "explore", "label": "Read the repo summary and refs", "command": "dev.kit explore" },\n'
    printf '    { "id": "action", "label": "Review grounded next steps", "command": "dev.kit action" },\n'
    printf '    { "id": "learn", "label": "Review lessons-learned workflow", "command": "dev.kit learn" }\n'
    printf '  ]\n'
    printf '}\n'
    return 0
  fi

  dev_kit_output_title "dev.kit"

  if [ "$repo_detected" = "true" ]; then
    dev_kit_output_summary "$(dev_kit_repo_name "$repo_root") • ${archetype} • profile ${profile}"
    dev_kit_output_section "workspace"
    dev_kit_output_row "path" "$repo_dir"
    dev_kit_output_row "repo root" "$repo_root"
    dev_kit_output_row "markers" "$(dev_kit_repo_markers_text "$repo_root")"
    if [ "$git_state" = "yes" ]; then
      dev_kit_output_section "start here"
      dev_kit_output_list_from_lines <<EOF
$(dev_kit_sync_start_here_text "$repo_root")
EOF
    fi
    dev_kit_output_section "read first"
    [ -n "$first_priority_ref" ] && dev_kit_output_list_item "$first_priority_ref"
    [ -n "$second_priority_ref" ] && dev_kit_output_list_item "$second_priority_ref"
    dev_kit_output_section "helpers"
    dev_kit_output_row "explore" "dev.kit explore"
    dev_kit_output_row "action" "dev.kit action"
    dev_kit_output_row "learn" "dev.kit learn"
    dev_kit_output_section "agent"
    dev_kit_output_list_from_lines <<EOF
$(dev_kit_repo_agent_contract_text "$repo_root" | dev_kit_output_first_lines 3)
EOF
  else
    dev_kit_output_summary "No repository detected in the current directory"
    dev_kit_output_section "workspace"
    dev_kit_output_row "path" "$repo_dir"
    dev_kit_output_row "guide" "navigate into a repo, then run dev.kit again"
    dev_kit_output_row "common signals" "README.md, package.json, .github, docs/, .git, Makefile"
    dev_kit_output_section "helpers"
    dev_kit_output_row "explore" "cd /path/to/repo && dev.kit"
    dev_kit_output_row "action" "cd /path/to/repo && dev.kit action"
    dev_kit_output_row "learn" "cd /path/to/repo && dev.kit learn"
  fi

  dev_kit_output_section "localhost"
  dev_kit_output_row "install" "$state"
  dev_kit_output_kv_list_from_pipe <<EOF
$(dev_kit_env_tool_lines)
EOF
}

command_usage() {
  local command_name="$1"
  echo "Usage: dev.kit ${command_name} [options]"
  echo
  echo "Options:"
  case "$command_name" in
    action)
      echo "  --json     Output machine-readable JSON"
      ;;
    explore|learn)
      echo "  --json     Output machine-readable JSON"
      ;;
    uninstall)
      echo "  --yes      Remove dev.kit without a confirmation prompt"
      ;;
  esac
}

command="${1:-home}"
format="text"
command_args=()

if [ "$#" -gt 0 ]; then
  shift
fi

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json)
      format="json"
      ;;
    *)
      command_args+=("$1")
      ;;
  esac
  shift
done

if [ "$command" = "--json" ]; then
  command="home"
  format="json"
fi

case "$command" in
  help|-h|--help)
    usage
    ;;
  home)
    if [ "${command_args[0]:-}" = "-h" ] || [ "${command_args[0]:-}" = "--help" ]; then
      home_usage
      exit 0
    fi
    dev_kit_run_home "$format" "${command_args[@]}"
    ;;
  *)
    fn="dev_kit_cmd_${command//-/_}"
    if command -v "$fn" >/dev/null 2>&1; then
      if [ "${command_args[0]:-}" = "-h" ] || [ "${command_args[0]:-}" = "--help" ]; then
        command_usage "$command"
        exit 0
      fi
      "$fn" "$format" "${command_args[@]}"
      exit 0
    fi
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
